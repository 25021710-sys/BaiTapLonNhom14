<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0"
            styleClass="main-container"
            stylesheets="@../style/AdminRoomManagementStyle.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminRoomManagementController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar" spacing="15">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <VBox>
                <Label styleClass="header-title" text="Giám Sát Phòng Đấu Giá"/>
                <Label styleClass="header-subtitle" text="Realtime monitoring hệ thống đấu giá"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       promptText="Tìm phòng / sản phẩm..."
                       prefWidth="250"/>

            <Button onAction="#handleRefresh"
                    styleClass="btn-refresh"
                    text="🔄 Refresh"/>
        </HBox>
    </top>

    <!-- CENTER: MASTER - DETAIL -->
    <center>
        <SplitPane dividerPositions="0.45">

            <!-- LEFT: TABLE LIST (MASTER) -->
            <VBox styleClass="left-panel" spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <Label text="Active Auction Rooms" styleClass="section-title"/>

                <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRoomId" text="Room"          prefWidth="70"/>
                        <TableColumn fx:id="colItem"   text="Item"          prefWidth="160"/>
                        <TableColumn fx:id="colPrice"  text="Current Price" prefWidth="130"/>
                        <TableColumn fx:id="colBids"   text="Bids"          prefWidth="60"/>
                        <TableColumn fx:id="colTime"   text="Time Left"     prefWidth="90"/>
                        <TableColumn fx:id="colStatus" text="Status"        prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="Không có phòng đang hoạt động"/>
                    </placeholder>
                </TableView>

            </VBox>

            <!-- RIGHT: DETAIL INSPECTOR -->
            <VBox styleClass="right-panel" spacing="12">
                <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>

                <Label text="Room Inspector" styleClass="section-title"/>

                <!-- Info Card -->
                <VBox styleClass="card" spacing="6">
                    <Label fx:id="lblRoomId"         text="Room: -"             styleClass="detail-label"/>
                    <Label fx:id="lblItem"            text="Item: -"             styleClass="detail-label"/>
                    <Label fx:id="lblStartPrice"      text="Start Price: -"      styleClass="detail-label"/>
                    <Label fx:id="lblCurrentPrice"    text="Current: -"          styleClass="detail-label"/>
                    <Label fx:id="lblHighestBidder"   text="Highest Bidder: -"   styleClass="detail-label"/>
                    <Label fx:id="lblTimeLeft"        text="Time Left: -"        styleClass="detail-label"/>
                </VBox>

                <!-- Admin Action Buttons -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button onAction="#handlePauseRoom"
                            styleClass="btn-pause"
                            text="⏸ Tạm Dừng"
                            prefWidth="110"/>
                    <Button onAction="#handleResumeRoom"
                            styleClass="btn-resume"
                            text="▶ Tiếp Tục"
                            prefWidth="110"/>
                    <Button onAction="#handleCloseRoom"
                            styleClass="btn-close-room"
                            text="⛔ Đóng Phòng"
                            prefWidth="120"/>
                    <Button onAction="#handleCancelRoom"
                            styleClass="btn-cancel-room"
                            text="🚫 Hủy Phòng"
                            prefWidth="120"/>
                </HBox>

                <!-- Live Bid Activity Log -->
                <TitledPane text="Live Bid Activity" VBox.vgrow="ALWAYS">
                    <TextArea fx:id="logArea"
                              editable="false"
                              wrapText="true"
                              prefHeight="220"/>
                </TitledPane>

                <!-- Participants -->
                <TitledPane text="Participants" expanded="false">
                    <ListView fx:id="participantList" prefHeight="130"/>
                </TitledPane>

            </VBox>

        </SplitPane>
    </center>

    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox styleClass="bottom-bar" spacing="10">
            <padding>
                <Insets top="8" right="15" bottom="8" left="15"/>
            </padding>
            <Label text="System Status:"/>
            <Label fx:id="lblSystemStatus" text="ONLINE" styleClass="status-ok"/>
        </HBox>
    </bottom>

</BorderPane>