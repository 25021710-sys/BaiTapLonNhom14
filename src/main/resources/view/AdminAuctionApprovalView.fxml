<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminAuctionApprovalController"
            stylesheets="@../style/AdminAuctionApprovalStyle.css">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="top-bar">
            <Label text="Duyệt yêu cầu tạo phiên đấu giá" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="txtSearch"
                       promptText="Tìm kiếm sản phẩm hoặc người bán..."
                       prefWidth="280.0" styleClass="search-field"/>
            <ComboBox fx:id="cbStatusFilter" prefWidth="160.0" promptText="Trạng thái"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.63">

            <!-- LEFT -->
            <VBox spacing="15.0" style="-fx-padding: 20;">
                <Label text="Danh sách yêu cầu" styleClass="section-title"/>
                <TableView fx:id="tblAuctionRequests"
                           VBox.vgrow="ALWAYS" prefWidth="700" maxWidth="700">
                    <columns>
                        <TableColumn fx:id="colRequestId"   text="ID"          prefWidth="70"/>
                        <TableColumn fx:id="colProductName" text="Tên sản phẩm" prefWidth="160"/>
                        <TableColumn fx:id="colSeller"      text="Người bán"    prefWidth="140"/>
                        <TableColumn fx:id="colStartTime"   text="Ngày mở"      prefWidth="100"/>
                        <TableColumn fx:id="colEndTime"     text="Kết thúc"     prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- RIGHT -->
            <ScrollPane fitToWidth="true">
                <VBox spacing="18.0" styleClass="detail-panel">

                    <Label text="Chi tiết yêu cầu" styleClass="detail-title"/>

                    <!-- IMAGE -->
                    <VBox spacing="10.0">
                        <Label text="Ảnh sản phẩm" styleClass="info-label"/>
                        <StackPane prefHeight="240" prefWidth="320" styleClass="image-preview">
                            <ImageView fx:id="imgProduct"
                                       fitWidth="300" fitHeight="220" preserveRatio="true"/>
                        </StackPane>
                    </VBox>

                    <!-- PRODUCT INFO -->
                    <VBox spacing="12.0">
                        <Label text="Thông tin sản phẩm" styleClass="section-title"/>
                        <GridPane hgap="15" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="140"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Tên sản phẩm:"  GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblProductName" text="---" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="value-label"/>

                            <Label text="Người bán:"     GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblSeller"      text="---" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="value-label"/>

                            <Label text="Danh mục:"      GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblCategory"    text="---" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="value-label"/>

                            <Label text="Giá khởi điểm:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblStartPrice"  text="---" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="value-label"/>

                            <!-- THÊM MỚI: Bước giá -->
                            <Label text="Bước giá:"      GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblStepPrice"   text="---" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="value-label"/>

                            <Label text="Bắt đầu:"       GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblStartTime"   text="---" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="value-label"/>

                            <Label text="Kết thúc:"      GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblEndTime"     text="---" GridPane.rowIndex="6" GridPane.columnIndex="1" styleClass="value-label"/>

                            <Label text="Ngày tạo:"      GridPane.rowIndex="7" GridPane.columnIndex="0" styleClass="info-label"/>
                            <Label fx:id="lblCreatedAt"   text="---" GridPane.rowIndex="7" GridPane.columnIndex="1" styleClass="value-label"/>
                        </GridPane>
                    </VBox>

                    <!-- DESCRIPTION -->
                    <VBox spacing="10.0">
                        <Label text="Mô tả sản phẩm" styleClass="section-title"/>
                        <TextArea fx:id="txtDescription" editable="false"
                                  wrapText="true" prefHeight="180"/>
                    </VBox>

                    <!-- REJECT REASON -->
                    <VBox spacing="10.0">
                        <Label text="Lý do từ chối (nếu có)" styleClass="section-title"/>
                        <TextArea fx:id="txtRejectReason"
                                  promptText="Nhập lý do từ chối..."
                                  wrapText="true" prefHeight="120"/>
                    </VBox>

                    <!-- BUTTONS -->
                    <HBox spacing="15.0" alignment="CENTER_LEFT">
                        <Button fx:id="btnApprove" text="Approve"
                                prefWidth="140" prefHeight="40"
                                onAction="#handleApprove" styleClass="approve-button"/>
                        <Button fx:id="btnReject" text="Reject"
                                prefWidth="140" prefHeight="40"
                                onAction="#handleReject" styleClass="reject-button"/>
                        <Button fx:id="btnRefresh" text="Refresh"
                                prefWidth="120" prefHeight="40"
                                onAction="#handleRefresh" styleClass="refresh-button"/>
                    </HBox>

                </VBox>
            </ScrollPane>

        </SplitPane>
    </center>

</BorderPane>
