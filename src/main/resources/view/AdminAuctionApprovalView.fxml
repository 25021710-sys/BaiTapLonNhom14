<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminAuctionApprovalController"
            stylesheets="@../style/DashBoardStyle.css"
            style="-fx-background-color: #f4f6f9;">

    <!-- ================= TOP BAR ================= -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15.0"
              style="-fx-padding: 15 20;
                     -fx-background-color: white;
                     -fx-border-color: #e0e0e0;
                     -fx-border-width: 0 0 1 0;">

            <Label text="Duyệt yêu cầu tạo phiên đấu giá"
                   style="-fx-font-size: 22px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1f2d3d;" />

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="txtSearch"
                       promptText="Tìm kiếm sản phẩm hoặc người bán..."
                       prefWidth="280.0"
                       style="-fx-background-radius: 10;" />

            <ComboBox fx:id="cbStatusFilter"
                      prefWidth="160.0"
                      promptText="Trạng thái"/>
        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>

        <SplitPane dividerPositions="0.58">

            <!-- ================= LEFT SIDE ================= -->
            <VBox spacing="15.0"
                  style="-fx-padding: 20;">

                <Label text="Danh sách yêu cầu"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1f2d3d;" />

                <TableView fx:id="tblAuctionRequests"
                           VBox.vgrow="ALWAYS">

                    <columns>

                        <TableColumn fx:id="colRequestId"
                                     text="ID"
                                     prefWidth="70"/>

                        <TableColumn fx:id="colProductName"
                                     text="Tên sản phẩm"
                                     prefWidth="220"/>

                        <TableColumn fx:id="colSeller"
                                     text="Người bán"
                                     prefWidth="150"/>

                        <TableColumn fx:id="colCategory"
                                     text="Danh mục"
                                     prefWidth="120"/>

                        <TableColumn fx:id="colStartPrice"
                                     text="Giá khởi điểm"
                                     prefWidth="140"/>

                        <TableColumn fx:id="colStatus"
                                     text="Trạng thái"
                                     prefWidth="120"/>

                    </columns>

                </TableView>

            </VBox>

            <!-- ================= RIGHT SIDE ================= -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background-color: transparent;
                               -fx-border-color: transparent;">

                <content>

                    <VBox spacing="18.0"
                          style="-fx-padding: 20;
                                 -fx-background-color: white;">

                        <!-- TITLE -->
                        <Label text="Chi tiết yêu cầu"
                               style="-fx-font-size: 20px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: #1f2d3d;" />

                        <!-- PRODUCT IMAGE -->
                        <VBox spacing="10.0">

                            <Label text="Ảnh sản phẩm"
                                   style="-fx-font-weight: bold;" />

                            <StackPane prefHeight="240"
                                       prefWidth="320"
                                       style="-fx-background-color: #f2f4f7;
                                              -fx-background-radius: 12;
                                              -fx-border-color: #dfe6e9;
                                              -fx-border-radius: 12;">

                                <ImageView fx:id="imgProduct"
                                           fitWidth="300"
                                           fitHeight="220"
                                           preserveRatio="true"/>

                            </StackPane>

                        </VBox>

                        <!-- PRODUCT INFO -->
                        <VBox spacing="12.0">

                            <Label text="Thông tin sản phẩm"
                                   style="-fx-font-size: 16px;
                                          -fx-font-weight: bold;" />

                            <GridPane hgap="15"
                                      vgap="12">

                                <columnConstraints>
                                    <ColumnConstraints prefWidth="140"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <!-- PRODUCT NAME -->
                                <Label text="Tên sản phẩm:"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblProductName"
                                       text="---"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="1"/>

                                <!-- SELLER -->
                                <Label text="Người bán:"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblSeller"
                                       text="---"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="1"/>

                                <!-- CATEGORY -->
                                <Label text="Danh mục:"
                                       GridPane.rowIndex="2"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblCategory"
                                       text="---"
                                       GridPane.rowIndex="2"
                                       GridPane.columnIndex="1"/>

                                <!-- START PRICE -->
                                <Label text="Giá khởi điểm:"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblStartPrice"
                                       text="---"
                                       GridPane.rowIndex="3"
                                       GridPane.columnIndex="1"/>

                                <!-- START TIME -->
                                <Label text="Bắt đầu:"
                                       GridPane.rowIndex="4"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblStartTime"
                                       text="---"
                                       GridPane.rowIndex="4"
                                       GridPane.columnIndex="1"/>

                                <!-- END TIME -->
                                <Label text="Kết thúc:"
                                       GridPane.rowIndex="5"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblEndTime"
                                       text="---"
                                       GridPane.rowIndex="5"
                                       GridPane.columnIndex="1"/>

                                <!-- CREATED -->
                                <Label text="Ngày tạo:"
                                       GridPane.rowIndex="6"
                                       GridPane.columnIndex="0"
                                       style="-fx-font-weight: bold;"/>

                                <Label fx:id="lblCreatedAt"
                                       text="---"
                                       GridPane.rowIndex="6"
                                       GridPane.columnIndex="1"/>

                            </GridPane>

                        </VBox>

                        <!-- DESCRIPTION -->
                        <VBox spacing="10.0">

                            <Label text="Mô tả sản phẩm"
                                   style="-fx-font-size: 16px;
                                          -fx-font-weight: bold;" />

                            <TextArea fx:id="txtDescription"
                                      editable="false"
                                      wrapText="true"
                                      prefHeight="180"
                                      style="-fx-background-radius: 10;" />

                        </VBox>

                        <!-- REJECT REASON -->
                        <VBox spacing="10.0">

                            <Label text="Lý do từ chối (nếu có)"
                                   style="-fx-font-size: 16px;
                                          -fx-font-weight: bold;" />

                            <TextArea fx:id="txtRejectReason"
                                      promptText="Nhập lý do từ chối..."
                                      wrapText="true"
                                      prefHeight="120"/>

                        </VBox>

                        <!-- ACTION BUTTONS -->
                        <HBox spacing="15.0"
                              alignment="CENTER_LEFT">

                            <Button fx:id="btnApprove"
                                    text="Approve"
                                    prefWidth="140"
                                    prefHeight="40"
                                    onAction="#handleApprove"
                                    style="-fx-background-color: #2ecc71;
                                           -fx-text-fill: white;
                                           -fx-font-size: 14px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;" />

                            <Button fx:id="btnReject"
                                    text="Reject"
                                    prefWidth="140"
                                    prefHeight="40"
                                    onAction="#handleReject"
                                    style="-fx-background-color: #e74c3c;
                                           -fx-text-fill: white;
                                           -fx-font-size: 14px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;" />

                            <Button fx:id="btnRefresh"
                                    text="Refresh"
                                    prefWidth="120"
                                    prefHeight="40"
                                    onAction="#handleRefresh"
                                    style="-fx-background-color: #3498db;
                                           -fx-text-fill: white;
                                           -fx-font-size: 14px;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 10;" />

                        </HBox>

                    </VBox>

                </content>

            </ScrollPane>

        </SplitPane>

    </center>

</BorderPane>