<HBox alignment="CENTER_LEFT" prefHeight="600.0" prefWidth="706.0" styleClass="root" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">

    <VBox alignment="TOP_CENTER" maxHeight="-Infinity" prefHeight="439.0" prefWidth="200.0" styleClass="sidebar">
        <HBox.margin>
            <Insets bottom="20.0" left="20.0" right="10.0" top="20.0" />
        </HBox.margin>
        <HBox prefHeight="73.0" prefWidth="200.0">
           <VBox.margin>
