<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<!-- Outer: full screen background -->
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<StackPane
        stylesheets="@../style/style.css"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.auction.client.controller.LoginController">
    <ImageView fitWidth="1920"
               fitHeight="1080"
               preserveRatio="false">

        <image>
            <Image url="@../image/background.jpg"/>
        </image>

    </ImageView>

    <StackPane.margin>
        <Insets/>
    </StackPane.margin>
    <padding>
        <Insets top="40" bottom="40" left="60" right="60"/>
    </padding>

    <!-- Frosted glass card -->
    <VBox alignment="CENTER_LEFT" spacing="12"
          maxWidth="520" minWidth="420"
          style="
    -fx-background-color: rgba(255,255,255,0.78);
    -fx-background-radius: 20;

    -fx-border-color: rgba(255,255,255,0.9);
    -fx-border-width: 1.5;
    -fx-border-radius: 20;

    -fx-effect: dropshadow(
        gaussian,
        rgba(0,0,0,0.15),
        25,
        0,
        0,
        8
    );
">
        <padding>
            <Insets top="40" bottom="40" left="36" right="36"/>
        </padding>

        <!-- Title -->
        <Label text="Welcome to Auction Online"
               textFill="#298a85"
               wrapText="true"
               maxWidth="Infinity">
            <font><Font name="Arial Bold" size="24.0"/></font>
            <VBox.margin><Insets bottom="4"/></VBox.margin>
        </Label>

        <!-- Subtitle -->
        <Label text="Please enter your details"
               style="-fx-font-size: 13px; -fx-text-fill: #7a9a9a;">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
        </Label>

        <!-- Email -->
        <Label text="Email Address"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2d5a5a;"/>
        <TextField fx:id="emailField"
                   promptText="you@example.com"
                   maxWidth="Infinity"
                   style="-fx-background-color: rgba(240,250,250,0.9);
                          -fx-border-color: #b2d8d8;
                          -fx-border-radius: 8; -fx-background-radius: 8;
                          -fx-padding: 10 12; -fx-font-size: 13px;"/>

        <!-- Password -->
        <Label text="Password"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2d5a5a;">
            <VBox.margin><Insets top="4"/></VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField"
                       promptText="••••••••"
                       maxWidth="Infinity"
                       style="-fx-background-color: rgba(240,250,250,0.9);
                              -fx-border-color: #b2d8d8;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 12; -fx-font-size: 13px;"/>

        <!-- Error -->
        <Label fx:id="errorLabel"
               textFill="#e74c3c"
               visible="false"
               wrapText="true"
               maxWidth="Infinity"
               style="-fx-font-size: 12px;"/>

        <!-- Sign in button -->
        <Button text="Sign in"
                onAction="#handleLogin"
                prefHeight="42"
                maxWidth="Infinity"
                style="-fx-background-color: #298a85;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-font-size: 14px;
                       -fx-background-radius: 9;
                       -fx-cursor: hand;">
            <VBox.margin><Insets top="10"/></VBox.margin>
        </Button>

        <!-- Register link -->
        <TextFlow textAlignment="CENTER" maxWidth="Infinity">
            <Text text="Don't have an account?  " style="-fx-font-size: 12px;"/>
            <Hyperlink onAction="#goToRegister" text="Register"
                       style="-fx-text-fill: #298a85; -fx-font-weight: bold;"/>
        </TextFlow>

    </VBox>

</StackPane>
