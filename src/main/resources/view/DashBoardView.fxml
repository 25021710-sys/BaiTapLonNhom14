<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane"
            maxHeight="-Infinity"
            maxWidth="-Infinity"
            minHeight="-Infinity"
            minWidth="-Infinity"
            prefHeight="760.0"
            prefWidth="1359.0"
            stylesheets="@../style/DashBoardStyle.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.DashBoardController">

   <!-- LEFT MENU -->
   <left>
      <VBox alignment="TOP_CENTER"
            spacing="20.0"
            stylesheets="@../style/DashBoardStyle.css"
            BorderPane.alignment="CENTER">

         <children>
            <Label text="AUCTION ONLINE">
               <padding>
                  <Insets top="20.0"/>
               </padding>
               <font>
                  <Font size="16.0"/>
               </font>
            </Label>

            <Button fx:id="btnAuctionList"
                    mnemonicParsing="false"
                    onAction="#handleAuctionList"
                    prefHeight="26.0"
                    prefWidth="118.0"
                    styleClass="menu-button"
                    text="Danh sách đấu giá"/>

            <Button fx:id="btnMyProducts"
                    mnemonicParsing="false"
                    styleClass="menu-button"
                    stylesheets="@../style/DashBoardStyle.css"
                    text="Sản phẩm của tôi"/>

            <Button mnemonicParsing="false"
                    prefWidth="118.0"
                    styleClass="menu-button"
                    stylesheets="@../style/DashBoardStyle.css"
                    text="Hỏi đáp????"/>

            <Button mnemonicParsing="false"
                    styleClass="menu-button"
                    stylesheets="@../style/DashBoardStyle.css"
                    text="Cài đặt"/>

            <Button mnemonicParsing="false"
                    onAction="#handleCreateAuctionView"
                    styleClass="menu-button"
                    stylesheets="@../style/DashBoardStyle.css"
                    text="Tạo phiên đấu giá"/>
         </children>
      </VBox>
   </left>

   <!-- CENTER CONTENT -->
   <center>
      <VBox prefHeight="760.0" prefWidth="1170.0" BorderPane.alignment="CENTER">

         <!-- TOP BAR -->
         <!-- TOP BAR (FIX RESPONSIVE - KEEP CENTER UNCHANGED) -->
         <HBox alignment="CENTER_LEFT"
               spacing="10.0"
               style="-fx-padding: 15 15 10 15;">

            <!-- SEARCH BAR -->
            <HBox fx:id="searchContainer"
                  alignment="CENTER_LEFT"
                  spacing="10.0"
                  styleClass="search-container"
                  HBox.hgrow="ALWAYS">

               <TextField fx:id="txtSearch"
                          promptText="Search for ..."
                          styleClass="search-field"
                          HBox.hgrow="ALWAYS"/>

               <FontAwesomeIcon fill="WHITE" glyphName="SEARCH"/>
            </HBox>

            <!-- PUSH RIGHT SIDE -->
            <HBox HBox.hgrow="ALWAYS"/>

            <!-- USER ACTIONS (FIXED, NEVER DISAPPEAR) -->
            <HBox alignment="CENTER_RIGHT"
                  spacing="10.0"
                  style="-fx-min-width: 180;">

               <!-- NOTIFICATION -->
               <Button mnemonicParsing="false"
                       prefHeight="33.0"
                       prefWidth="38.0"
                       style="-fx-background-radius: 5; -fx-background-color: #142932;">
                  <graphic>
                     <FontAwesomeIcon fill="WHITE" glyphName="BELL_O" size="18"/>
                  </graphic>
               </Button>

               <!-- PROFILE -->
               <Button fx:id="btnProfile"
                       mnemonicParsing="false"
                       onAction="#handleGoToProfile"
                       style="-fx-background-color: transparent; -fx-cursor: hand;"
                       prefHeight="33.0">

                  <graphic>
                     <HBox alignment="CENTER_RIGHT" spacing="8.0">

                        <Circle fx:id="profileCircle"
                                fill="#1f93ff"
                                radius="18.0"
                                stroke="WHITE"
                                strokeType="INSIDE"
                                strokeWidth="2.0"/>

                        <Label fx:id="lblUsername"
                               text="User"
                               style="-fx-text-fill: black; -fx-font-size: 14px;"/>
                     </HBox>
                  </graphic>
               </Button>

            </HBox>

         </HBox>

         <!-- MAIN SCROLL -->
         <ScrollPane fx:id="mainScrollPane"
                     fitToWidth="true"
                     VBox.vgrow="ALWAYS"
                     hbarPolicy="NEVER"
                     vbarPolicy="ALWAYS"
                     style="-fx-background-color: transparent;">

            <content>
               <VBox spacing="25.0" style="-fx-padding: 20;">

                  <!-- SECTION 1 -->
                  <VBox spacing="10.0">

                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Những bid bạn đang tham gia"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <HBox HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnLeftBids"
                                text="◀"
                                style="-fx-background-color: transparent; -fx-font-size: 16px;"/>

                        <Button fx:id="btnRightBids"
                                text="▶"
                                style="-fx-background-color: transparent; -fx-font-size: 16px;"/>
                     </HBox>

                     <ScrollPane fx:id="spBidsJoined"
                                 fitToHeight="true"
                                 fitToWidth="false"
                                 hbarPolicy="NEVER"
                                 vbarPolicy="NEVER"
                                 pannable="true"
                                 prefHeight="300.0"
                                 prefViewportHeight="280.0"
                                 style="-fx-background-color: transparent;">

                        <content>
                           <HBox fx:id="pnlBidsJoined"
                                 spacing="15.0"
                                 alignment="CENTER_LEFT"
                                 style="-fx-padding: 10;"/>
                        </content>
                     </ScrollPane>
                  </VBox>

                  <!-- SECTION 2 -->
                  <VBox spacing="10.0">

                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Sản phẩm nổi bật"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <HBox HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnLeftFeatured"
                                text="◀"
                                style="-fx-background-color: transparent; -fx-font-size: 16px;"/>

                        <Button fx:id="btnRightFeatured"
                                text="▶"
                                style="-fx-background-color: transparent; -fx-font-size: 16px;"/>
                     </HBox>

                     <ScrollPane fx:id="spFeaturedProducts"
                                 fitToHeight="true"
                                 fitToWidth="false"
                                 hbarPolicy="NEVER"
                                 vbarPolicy="NEVER"
                                 pannable="true"
                                 prefHeight="300.0"
                                 prefViewportHeight="280.0"
                                 style="-fx-background-color: transparent;">

                        <content>
                           <HBox fx:id="pnlFeaturedProducts"
                                 spacing="15.0"
                                 alignment="CENTER_LEFT"
                                 style="-fx-padding: 10;"/>
                        </content>
                     </ScrollPane>
                  </VBox>

                  <!-- SECTION 3 -->
                  <VBox spacing="10.0">

                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <Label text="Những sản phẩm bạn quan tâm"
                               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                        <HBox HBox.hgrow="ALWAYS"/>

                        <Button fx:id="btnLeftFavorite"
                                text="◀"
                                style="-fx-background-color: transparent; -fx-font-size: 16px;"/>

                        <Button fx:id="btnRightFavorite"
                                text="▶"
                                style="-fx-background-color: transparent; -fx-font-size: 16px;"/>
                     </HBox>

                     <ScrollPane fx:id="spFavoriteProducts"
                                 fitToHeight="true"
                                 fitToWidth="false"
                                 hbarPolicy="NEVER"
                                 vbarPolicy="NEVER"
                                 pannable="true"
                                 prefHeight="300.0"
                                 prefViewportHeight="280.0"
                                 style="-fx-background-color: transparent;">

                        <content>
                           <HBox fx:id="pnlFavoriteProducts"
                                 spacing="15.0"
                                 alignment="CENTER_LEFT"
                                 style="-fx-padding: 10;"/>
                        </content>
                     </ScrollPane>
                  </VBox>

               </VBox>
            </content>
         </ScrollPane>

      </VBox>
   </center>

</BorderPane>