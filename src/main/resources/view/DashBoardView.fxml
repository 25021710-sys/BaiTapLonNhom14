<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.control.Separator?>
<BorderPane fx:id="rootPane"
            maxWidth="Infinity"
            maxHeight="Infinity"
            stylesheets="@../style/DashBoardStyle.css"
            style="-fx-background-color: #f4f6f9;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.DashBoardController">

   <!-- LEFT MENU -->
   <left>
      <VBox alignment="TOP_CENTER"
            spacing="20.0"
            style="-fx-background-color: #142932; -fx-padding: 20; -fx-border-color: #0e1d23; -fx-border-width: 0 1 0 0;"
            BorderPane.alignment="CENTER">

         <Button text="AUCTION ONLINE"
                 mnemonicParsing="false"
                 onAction="#handleGoToDashboard"
                 style="-fx-background-color: transparent;
            -fx-text-fill: white;
            -fx-font-weight: bold;
            -fx-font-size: 18px;
            -fx-cursor: hand;">
            <padding>
               <Insets top="20.0" bottom="15.0"/>
            </padding>
         </Button>

         <Button fx:id="btnHome"
                 mnemonicParsing="false"
                 onAction="#handleGoToDashboard"
                 prefHeight="35.0"
                 prefWidth="180.0"
                 styleClass="menu-button"
                 text="Trang chủ"/>

         <Button fx:id="btnJoinedAuction"
                 mnemonicParsing="false"
                 styleClass="menu-button"
                 prefHeight="35.0"
                 prefWidth="180.0"
                 text="Phiên đấu giá đang tham gia"/>

         <Button fx:id="btnMyAuction"
                 mnemonicParsing="false"
                 prefWidth="180.0"
                 prefHeight="35.0"
                 styleClass="menu-button"
                 text="Phiên đấu giá của tôi"/>

         <Button fx:id="btnCreateAuction"
                 mnemonicParsing="false"
                 onAction="#handleCreateAuctionView"
                 prefWidth="180.0"
                 prefHeight="35.0"
                 styleClass="menu-button"
                 text="Tạo phiên đấu giá"/>
         <!-- ADMIN SECTION -->
         <VBox fx:id="adminSection"
               spacing="10"
               alignment="TOP_CENTER"
               visible="false"
               managed="false"
               styleClass="admin-section">

            <Separator prefWidth="180"/>

            <Label text="ADMIN PANEL"
                   styleClass="admin-title"/>

            <Button fx:id="btnAuctionApproval"
                    mnemonicParsing="false"
                    prefWidth="180.0"
                    prefHeight="35.0"
                    text="Duyệt phiên đấu giá"
                    styleClass="menu-button"
                    onAction="#handleAuctionApproval"/>

            <Button fx:id="btnManageRooms"
                    mnemonicParsing="false"
                    prefWidth="180.0"
                    prefHeight="35.0"
                    text="Quản lý phòng đấu giá"
                    styleClass="menu-button"
                    onAction="#handleManageRooms"/>

            <Button fx:id="btnManageUsers"
                    mnemonicParsing="false"
                    prefWidth="180.0"
                    prefHeight="35.0"
                    text="Quản lý người dùng"
                    styleClass="menu-button"
                    onAction="#handleManageUsers"/>

         </VBox>
      </VBox>
   </left>

   <!-- CENTER CONTENT -->
   <center>
      <VBox prefHeight="760.0"
            prefWidth="1170.0"
            style="-fx-background-color: transparent;"
            BorderPane.alignment="CENTER">
         <children>
            <!-- TOP BAR -->
            <HBox alignment="CENTER_LEFT"
                  spacing="15.0"
                  style="-fx-padding: 10 20; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
               <children>
                  <!-- SEARCH BAR -->
                  <HBox fx:id="searchContainer"
                        alignment="CENTER_LEFT"
                        spacing="10.0"
                        styleClass="search-container"
                        style="-fx-background-color: #f2f4f7; -fx-padding: 8 12; -fx-background-radius: 12;"
                        HBox.hgrow="ALWAYS"
                        minWidth="100"
                        maxWidth="600">
                     <children>
                        <TextField fx:id="txtSearch"
                                   promptText="Search for ..."
                                   style="-fx-background-color: transparent;"
                                   HBox.hgrow="ALWAYS"/>
                        <FontAwesomeIcon fill="#555555" glyphName="SEARCH"/>
                     </children>
                  </HBox>

                  <!-- SPACER -->
                  <Region HBox.hgrow="ALWAYS"/>

                  <!-- USER ACTIONS -->
                  <HBox alignment="CENTER_RIGHT"
                        spacing="15.0"
                        minWidth="230.0"
                        prefWidth="230.0"
                        HBox.hgrow="NEVER">
                     <children>
                        <Button mnemonicParsing="false"
                                style="-fx-background-radius: 10; -fx-background-color: #142932; -fx-cursor: hand;"
                                prefHeight="36.0" prefWidth="42.0">
                           <graphic>
                              <FontAwesomeIcon fill="WHITE" glyphName="BELL_O" size="18"/>
                           </graphic>
                        </Button>

                        <Button fx:id="btnProfile" onAction="#handleGoToProfile"
                                style="-fx-background-color: transparent; -fx-cursor: hand;">
                           <graphic>
                              <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                 <children>
                                    <Circle fx:id="profileCircle" fill="#1f93ff" radius="18.0" stroke="WHITE" strokeWidth="2.0"/>
                                    <Label fx:id="lblUsername" text="User"
                                           minWidth="50"
                                           maxWidth="100.0"
                                           textOverrun="ELLIPSIS"
                                           style="-fx-text-fill: #1f2d3d; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                                 </children>
                              </HBox>
                           </graphic>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- MAIN SCROLL -->
            <ScrollPane fx:id="mainScrollPane"
                        fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER"
                        vbarPolicy="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
               <content>
                  <VBox spacing="30.0"
                        style="-fx-padding: 25; -fx-background-color: transparent;">
                     <children>
                        <!-- SECTION 1 -->
                        <VBox spacing="12.0"
                              style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #e0e0e0;">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label text="Những bid bạn đang tham gia"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnLeftBids"
                                            text="◀"
                                            style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                                    <Button fx:id="btnRightBids"
                                            text="▶"
                                            style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                                 </children>
                              </HBox>
                              <ScrollPane fx:id="spBidsJoined"
                                          fitToHeight="true"
                                          hbarPolicy="NEVER"
                                          vbarPolicy="NEVER"
                                          pannable="true"
                                          prefHeight="300.0"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                 <content>
                                    <HBox fx:id="pnlBidsJoined"
                                          spacing="15.0"
                                          alignment="CENTER_LEFT"
                                          style="-fx-padding: 10;"/>
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>

                        <!-- SECTION 2 -->
                        <VBox spacing="12.0"
                              style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #e0e0e0;">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label text="Sản phẩm nổi bật"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnLeftFeatured"
                                            text="◀"
                                            style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                                    <Button fx:id="btnRightFeatured"
                                            text="▶"
                                            style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                                 </children>
                              </HBox>
                              <ScrollPane fx:id="spFeaturedProducts"
                                          fitToHeight="true"
                                          hbarPolicy="NEVER"
                                          vbarPolicy="NEVER"
                                          pannable="true"
                                          prefHeight="300.0"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                 <content>
                                    <HBox fx:id="pnlFeaturedProducts"
                                          spacing="15.0"
                                          alignment="CENTER_LEFT"
                                          style="-fx-padding: 10;"/>
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>

                        <!-- SECTION 3 -->
                        <VBox spacing="12.0"
                              style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #e0e0e0;">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label text="Những sản phẩm bạn quan tâm"
                                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button fx:id="btnLeftFavorite"
                                            text="◀"
                                            style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                                    <Button fx:id="btnRightFavorite"
                                            text="▶"
                                            style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-cursor: hand;"/>
                                 </children>
                              </HBox>
                              <ScrollPane fx:id="spFavoriteProducts"
                                          fitToHeight="true"
                                          hbarPolicy="NEVER"
                                          vbarPolicy="NEVER"
                                          pannable="true"
                                          prefHeight="300.0"
                                          style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                 <content>
                                    <HBox fx:id="pnlFavoriteProducts"
                                          spacing="15.0"
                                          alignment="CENTER_LEFT"
                                          style="-fx-padding: 10;"/>
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
