<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1100.0"
            prefHeight="700.0"
            style="-fx-background-color: #f5f7fa;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AuctionRoomController">

    <!-- ========================= -->
    <!-- LEFT MAIN CONTENT -->
    <!-- ========================= -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">

            <!-- TITLE + STATUS -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblAuctionTitle"
                       text="Đấu giá: Tranh sơn dầu cổ điển"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2d3d;"/>

                <Label fx:id="lblAuctionStatus"
                       text="ĐANG DIỄN RA"
                       style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 4 10; -fx-background-radius: 8; -fx-font-weight: bold;"/>
            </HBox>

            <!-- IMAGE + BASIC INFO -->
            <HBox spacing="20">

                <!-- PRODUCT IMAGE PREVIEW -->
                <VBox spacing="10">
                    <ImageView fx:id="imgMainProduct"
                               fitWidth="430"
                               fitHeight="300"
                               preserveRatio="true"
                               style="-fx-border-color: #ddd; -fx-background-color: white;"/>

                    <!-- THUMBNAILS -->
                    <HBox spacing="10">
                        <ImageView fx:id="imgThumb1" fitWidth="70" fitHeight="50" preserveRatio="true"
                                   style="-fx-border-color: #ccc; -fx-background-color: white;"/>
                        <ImageView fx:id="imgThumb2" fitWidth="70" fitHeight="50" preserveRatio="true"
                                   style="-fx-border-color: #ccc; -fx-background-color: white;"/>
                        <ImageView fx:id="imgThumb3" fitWidth="70" fitHeight="50" preserveRatio="true"
                                   style="-fx-border-color: #ccc; -fx-background-color: white;"/>
                        <ImageView fx:id="imgThumb4" fitWidth="70" fitHeight="50" preserveRatio="true"
                                   style="-fx-border-color: #ccc; -fx-background-color: white;"/>
                    </HBox>
                </VBox>

                <!-- PRODUCT INFO -->
                <VBox spacing="12" HBox.hgrow="ALWAYS">

                    <!-- PRODUCT INFO -->
                    <Label text="Thông tin sản phẩm"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <GridPane hgap="10" vgap="10"
                              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd;">

                        <Label text="Danh mục:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblCategory" text="Art" style="-fx-font-weight: bold;"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <!-- ART DETAILS -->
                        <Label fx:id="lblArtistTitle" text="Tác giả:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="lblArtist" text="Vincent Van Gogh"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label fx:id="lblArtYearTitle" text="Năm sáng tác:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblArtYear" text="1889"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label fx:id="lblMaterialTitle" text="Chất liệu:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="lblMaterial" text="Sơn dầu trên canvas"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Người bán:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="lblSellerInline" text="duyanh_store"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>

                    <!-- AUCTION INFO -->
                    <Label text="Thông tin đấu giá"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <GridPane hgap="10" vgap="10"
                              style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd;">

                        <Label text="Giá khởi điểm:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblStartPrice" text="1.000.000 VNĐ" style="-fx-font-weight: bold;"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Giá hiện tại:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="lblCurrentPrice" text="2.350.000 VNĐ"
                               style="-fx-font-weight: bold; -fx-text-fill: #e67e22; -fx-font-size: 16px;"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Bước giá:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblStepPrice" text="50.000 VNĐ"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Người dẫn đầu:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="lblLeadingUser" text="user_abc***"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Số lượt bid:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="lblTotalBids" text="35"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>

                    <!-- DESCRIPTION -->
                    <Label text="Mô tả"
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <TextArea fx:id="txtDescription"
                              editable="false"
                              wrapText="true"
                              prefRowCount="6"
                              text="Tranh sơn dầu cổ điển, bảo quản tốt, phù hợp trưng bày."
                              style="-fx-background-color: white; -fx-border-color: #ddd;"/>

                </VBox>

            </HBox>

            <!-- TABS: BID HISTORY + CHAT -->
            <TabPane prefHeight="250" VBox.vgrow="ALWAYS">

                <!-- BID HISTORY -->
                <Tab text="Lịch sử đấu giá">
                    <VBox spacing="10" style="-fx-padding: 10;">

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Bộ lọc:"/>
                            <ComboBox fx:id="cbBidFilter" promptText="Tất cả" prefWidth="180"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button text="Refresh" onAction="#handleRefreshBidHistory"/>
                        </HBox>

                        <TableView fx:id="tblBidHistory" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colBidTime" text="Thời gian" prefWidth="180"/>
                                <TableColumn fx:id="colBidUser" text="Người bid" prefWidth="200"/>
                                <TableColumn fx:id="colBidAmount" text="Giá bid" prefWidth="200"/>
                                <TableColumn fx:id="colBidType" text="Loại" prefWidth="150"/>
                            </columns>
                        </TableView>

                    </VBox>
                </Tab>

                <!-- CHAT -->
                <Tab text="Chat / Hỏi đáp">
                    <BorderPane style="-fx-padding: 10;">

                        <center>
                            <ListView fx:id="lvChatMessages"/>
                        </center>

                        <bottom>
                            <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
                                <TextField fx:id="txtChatInput"
                                           promptText="Nhập tin nhắn..."
                                           HBox.hgrow="ALWAYS"/>

                                <Button text="Gửi"
                                        onAction="#handleSendChat"
                                        style="-fx-background-color: #1f93ff; -fx-text-fill: white;"/>
                            </HBox>
                        </bottom>

                    </BorderPane>
                </Tab>

            </TabPane>

        </VBox>
    </center>

    <!-- ========================= -->
    <!-- RIGHT BID PANEL -->
    <!-- ========================= -->
    <right>
        <ScrollPane fitToWidth="true"
                    prefWidth="340"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent;">

            <content>
                <VBox spacing="15"
                      prefWidth="320"
                      style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #ddd;">

                    <!-- COUNTDOWN -->
                    <Label text="Thời gian còn lại"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <Label fx:id="lblCountdown"
                           text="00:15:42"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>

                    <Separator/>

                    <!-- CURRENT PRICE -->
                    <Label text="Giá hiện tại"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <Label fx:id="lblCurrentPriceRight"
                           text="2.350.000 VNĐ"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>

                    <Label fx:id="lblYourStatus"
                           text="Bạn đang bị vượt giá!"
                           style="-fx-text-fill: red; -fx-font-weight: bold;"/>

                    <Separator/>

                    <!-- BID INPUT -->
                    <Label text="Nhập giá bạn muốn đặt"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <TextField fx:id="txtBidAmount" promptText="Ví dụ: 2400000"/>

                    <HBox spacing="10">
                        <Button text="+10K" onAction="#handleQuickBid10k" prefWidth="70"/>
                        <Button text="+50K" onAction="#handleQuickBid50k" prefWidth="70"/>
                        <Button text="+100K" onAction="#handleQuickBid100k" prefWidth="90"/>
                    </HBox>

                    <Button text="ĐẶT GIÁ NGAY"
                            onAction="#handlePlaceBid"
                            prefHeight="45"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>

                    <!-- ERROR -->
                    <Label fx:id="lblBidError"
                           visible="false"
                           style="-fx-text-fill: red; -fx-font-weight: bold;"/>

                    <Separator/>

                    <!-- AUTO BID -->
                    <Label text="Auto-bid"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <CheckBox fx:id="chkAutoBid" text="Bật Auto-bid"/>

                    <TextField fx:id="txtAutoBidMax"
                               promptText="Giá tối đa (Auto-bid)"
                               disable="true"/>

                    <Button text="Kích hoạt Auto-bid"
                            onAction="#handleEnableAutoBid"
                            style="-fx-background-color: #1f93ff; -fx-text-fill: white;"/>

                    <Separator/>

                    <!-- SELLER INFO -->
                    <Label text="Người bán"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <VBox spacing="5" style="-fx-background-color: #f5f7fa; -fx-padding: 10; -fx-border-color: #ddd;">
                        <Label fx:id="lblSellerName" text="Seller: duyanh_store"/>
                        <Label fx:id="lblSellerRating" text="Rating: ⭐ 4.8/5"/>
                        <Label fx:id="lblSellerProducts" text="Sản phẩm đã bán: 120"/>

                        <HBox spacing="10" style="-fx-padding: 5 0 0 0;">
                            <Button text="Xem profile" onAction="#handleViewSellerProfile" prefWidth="130"/>
                            <Button text="Nhắn tin" onAction="#handleMessageSeller" prefWidth="100"/>
                        </HBox>
                    </VBox>

                    <Separator/>

                    <!-- AUCTION INFO -->
                    <Label text="Thông tin phiên"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <VBox spacing="5" style="-fx-background-color: #f5f7fa; -fx-padding: 10; -fx-border-color: #ddd;">
                        <Label fx:id="lblAuctionId" text="Auction ID: #AUC00123"/>
                        <Label fx:id="lblStartTime" text="Bắt đầu: 05/05/2026 07:00"/>
                        <Label fx:id="lblEndTime" text="Kết thúc: 05/05/2026 08:00"/>
                        <Label fx:id="lblParticipants" text="Người tham gia: 18"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </right>
</BorderPane>