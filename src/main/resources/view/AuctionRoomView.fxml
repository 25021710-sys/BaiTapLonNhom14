<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane
        prefWidth="1200.0"
        prefHeight="750.0"
        stylesheets="@../style/AuctionRoomStyle.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.auction.client.controller.AuctionRoomController">

    <!-- ═══════════════════════════════════════════════════════════
         TOP HEADER BAR
    ═══════════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="0">

            <!-- Title + Badge -->
            <VBox alignment="CENTER_LEFT" spacing="4" style="-fx-padding: 0 24 0 20;">
                <Label fx:id="lblAuctionTitle"
                       text="Đấu giá: —"
                       styleClass="header-title"
                       maxWidth="360" wrapText="true"/>
                <Label fx:id="lblAuctionStatus"
                       text="ĐANG DIỄN RA"
                       styleClass="badge-running"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Stats -->
            <HBox spacing="0" alignment="CENTER">

                <VBox styleClass="header-stat-block" alignment="CENTER" minWidth="160">
                    <Label text="SỐ DƯ CỦA TÔI" styleClass="stat-label"/>
                    <Label fx:id="lblMyBalance" text="—"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>

                <Separator orientation="VERTICAL" style="-fx-padding: 10 0;"/>

                <VBox styleClass="header-stat-block" alignment="CENTER" minWidth="110">
                    <Label text="NGƯỜI THAM GIA" styleClass="stat-label"/>
                    <Label fx:id="lblParticipants" text="—" styleClass="stat-value"/>
                </VBox>

                <Separator orientation="VERTICAL" style="-fx-padding: 10 0;"/>

                <VBox styleClass="header-stat-block" alignment="CENTER" minWidth="110">
                    <Label text="LƯỢT BID" styleClass="stat-label"/>
                    <Label fx:id="lblTotalBids" text="0" styleClass="stat-value"/>
                </VBox>

                <Separator orientation="VERTICAL" style="-fx-padding: 10 0;"/>

                <VBox styleClass="header-stat-block" alignment="CENTER" minWidth="160">
                    <Label text="GIÁ HIỆN TẠI" styleClass="stat-label"/>
                    <Label fx:id="lblCurrentPrice" text="—" styleClass="stat-value-price"/>
                </VBox>

            </HBox>

        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════════
         CENTER — main scroll area
    ═══════════════════════════════════════════════════════════ -->
    <center>
        <ScrollPane styleClass="main-scroll" fitToWidth="true"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="main-content" spacing="14">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                    <!-- ── ROW 1: IMAGE + PRODUCT INFO ── -->
                    <HBox spacing="14">

                        <!-- Image column -->
                        <VBox spacing="8" minWidth="340" maxWidth="360">

                            <!-- Main image -->
                            <StackPane styleClass="image-container" prefHeight="240">
                                <Label text="📷  Chưa có ảnh" styleClass="image-placeholder"/>
                                <ImageView fx:id="imgMainProduct"
                                           fitWidth="340" fitHeight="240"
                                           preserveRatio="true"/>
                            </StackPane>

                            <!-- Thumbnails -->
                            <HBox spacing="6">
                                <StackPane styleClass="thumb-container" prefWidth="74" prefHeight="52">
                                    <ImageView fx:id="imgThumb1" fitWidth="74" fitHeight="52" preserveRatio="true"/>
                                </StackPane>
                                <StackPane styleClass="thumb-container" prefWidth="74" prefHeight="52">
                                    <ImageView fx:id="imgThumb2" fitWidth="74" fitHeight="52" preserveRatio="true"/>
                                </StackPane>
                                <StackPane styleClass="thumb-container" prefWidth="74" prefHeight="52">
                                    <ImageView fx:id="imgThumb3" fitWidth="74" fitHeight="52" preserveRatio="true"/>
                                </StackPane>
                                <StackPane styleClass="thumb-container" prefWidth="74" prefHeight="52">
                                    <ImageView fx:id="imgThumb4" fitWidth="74" fitHeight="52" preserveRatio="true"/>
                                </StackPane>
                            </HBox>

                        </VBox>

                        <!-- Info cards column -->
                        <VBox spacing="10" HBox.hgrow="ALWAYS">

                            <!-- Product info card -->
                            <!-- Product info + description card (gộp lại) -->
                            <VBox styleClass="info-card" VBox.vgrow="ALWAYS">

                                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                                    <Label text="Thông tin sản phẩm" styleClass="card-title"/>
                                </HBox>

                                <Separator styleClass="card-divider"/>

                                <VBox spacing="0" style="-fx-padding: 2 0 4 0;">

                                    <HBox styleClass="info-row">
                                        <Label text="Danh mục" styleClass="info-key"/>
                                        <Label fx:id="lblCategory" text="—" styleClass="info-val"/>
                                    </HBox>

                                    <HBox styleClass="info-row" style="-fx-border-color: transparent;">
                                        <Label text="Mô tả" styleClass="info-key"/>
                                    </HBox>

                                    <TextArea fx:id="txtDescription"
                                              editable="false"
                                              wrapText="true"
                                              prefRowCount="6"
                                              styleClass="desc-area"/>
                                </VBox>

                            </VBox>

                            <!-- Mô tả riêng bên dưới -->

                            <!-- Auction info card -->
                            <VBox styleClass="info-card">
                                <HBox styleClass="card-header" alignment="CENTER_LEFT">
                                    <Label text="⚖  Thông tin đấu giá" styleClass="card-title"/>
                                </HBox>
                                <Separator styleClass="card-divider"/>
                                <VBox spacing="0" style="-fx-padding: 2 0 4 0;">
                                    <HBox styleClass="info-row">
                                        <Label text="Giá khởi điểm" styleClass="info-key"/>
                                        <Label fx:id="lblStartPrice" text="—" styleClass="info-val"/>
                                    </HBox>
                                    <HBox styleClass="info-row">
                                        <Label text="Bước giá tối thiểu" styleClass="info-key"/>
                                        <Label fx:id="lblStepPrice" text="—" styleClass="info-val"/>
                                    </HBox>
                                    <HBox styleClass="info-row">
                                        <Label text="Người dẫn đầu" styleClass="info-key"/>
                                        <Label fx:id="lblLeadingUser" text="---" styleClass="info-val-winner"/>
                                    </HBox>
                                    <HBox styleClass="info-row">
                                        <Label text="Bắt đầu" styleClass="info-key"/>
                                        <Label fx:id="lblStartTime" text="—" styleClass="info-val-mono"/>
                                    </HBox>
                                    <HBox styleClass="info-row">
                                        <Label text="Kết thúc" styleClass="info-key"/>
                                        <Label fx:id="lblEndTime" text="—" styleClass="info-val-mono"/>
                                    </HBox>
                                    <HBox styleClass="info-row" style="-fx-border-color: transparent;">
                                        <Label text="Mã phiên" styleClass="info-key"/>
                                        <Label fx:id="lblAuctionId" text="—" styleClass="info-val-mono"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                        </VBox>
                    </HBox>

                    <!-- ── ROW 2: TABS ── -->
                    <TabPane styleClass="main-tabs" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

                        <!-- Tab 1: Lịch sử đấu giá -->
                        <Tab text="📋  Lịch sử đấu giá">
                            <VBox spacing="8" style="-fx-padding: 10 12 10 12;">

                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Lọc:" styleClass="filter-label"/>
                                    <ComboBox fx:id="cbBidFilter"
                                              promptText="Tất cả"
                                              prefWidth="160"
                                              styleClass="filter-combo"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="🔄  Làm mới"
                                            onAction="#handleRefreshBidHistory"
                                            styleClass="btn-secondary"/>
                                </HBox>

                                <TableView fx:id="tblBidHistory"
                                           styleClass="bid-table"
                                           prefHeight="220"
                                           VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colBidTime"   text="Thời gian"   prefWidth="170"/>
                                        <TableColumn fx:id="colBidUser"   text="Người bid"   prefWidth="200"/>
                                        <TableColumn fx:id="colBidAmount" text="Giá bid"      prefWidth="190"/>
                                        <TableColumn fx:id="colBidType"   text="Loại bid"    prefWidth="120"/>
                                    </columns>
                                    <placeholder>
                                        <Label text="Chưa có lượt bid nào"
                                               style="-fx-text-fill: #90A4AE; -fx-font-size: 13px;"/>
                                    </placeholder>
                                </TableView>

                            </VBox>
                        </Tab>

                        <!-- Tab 2: Biểu đồ giá realtime -->
                        <Tab text="📈  Biểu đồ giá realtime">
                            <VBox style="-fx-padding: 10 12 10 12;" VBox.vgrow="ALWAYS">
                                <LineChart fx:id="bidHistoryChart"
                                           styleClass="price-chart"
                                           animated="false"
                                           VBox.vgrow="ALWAYS"
                                           prefHeight="240">
                                    <xAxis>
                                        <NumberAxis fx:id="chartXAxis"
                                                    label="Thời gian (giây)"
                                                    autoRanging="true"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis fx:id="chartYAxis"
                                                    label="Giá (VNĐ)"
                                                    autoRanging="true"/>
                                    </yAxis>
                                </LineChart>
                            </VBox>
                        </Tab>
                    </TabPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════════
         RIGHT — Bid panel
    ═══════════════════════════════════════════════════════════ -->
    <right>
        <ScrollPane styleClass="right-scroll"
                    fitToWidth="true"
                    prefWidth="300"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED">
            <content>
                <VBox styleClass="bid-panel" spacing="0" prefWidth="300">

                    <!-- ① Countdown -->
                    <VBox styleClass="panel-section" spacing="4">
                        <Label text="⏳  Thời gian còn lại" styleClass="panel-section-title"/>
                        <Label fx:id="lblCountdown" text="00:00:00" styleClass="countdown-label"/>
                        <Label text="đến khi phiên đóng" styleClass="countdown-sub"/>
                    </VBox>
                    <Separator styleClass="panel-sep"/>

                    <!-- ② Current price + status -->
                    <VBox styleClass="panel-section" spacing="6">
                        <Label text="💰  Giá hiện tại" styleClass="panel-section-title"/>
                        <Label fx:id="lblCurrentPriceRight" text="—" styleClass="current-price-big"/>
                        <Label fx:id="lblYourStatus" text="Chưa có người đặt giá" styleClass="status-neutral"/>
                    </VBox>
                    <Separator styleClass="panel-sep"/>

                    <!-- ③ Place bid -->
                    <VBox styleClass="panel-section" spacing="8">
                        <Label text="🎯  Đặt giá" styleClass="panel-section-title"/>

                        <TextField fx:id="txtBidAmount"
                                   promptText="Nhập số tiền"
                                   styleClass="bid-input"/>

                        <!-- Quick bid -->
                        <HBox spacing="6">
                            <Button text="+10K"  onAction="#handleQuickBid10k"
                                    styleClass="btn-quick" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="+50K"  onAction="#handleQuickBid50k"
                                    styleClass="btn-quick" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Button text="+100K" onAction="#handleQuickBid100k"
                                    styleClass="btn-quick" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <Button text="ĐẶT GIÁ NGAY 🚀"
                                onAction="#handlePlaceBid"
                                styleClass="btn-bid-primary"
                                maxWidth="Infinity"
                                prefHeight="44"/>

                        <Label fx:id="lblBidError"
                               visible="false"
                               wrapText="true"
                               styleClass="bid-error-label"
                               maxWidth="Infinity"/>
                    </VBox>
                    <Separator styleClass="panel-sep"/>

                    <!-- ④ Auto-bid -->
                    <VBox styleClass="panel-section" spacing="8">
                        <Label text="🤖  Auto-Bid" styleClass="panel-section-title"/>

                        <CheckBox fx:id="chkAutoBid"
                                  text="Bật Auto-bid tự động"
                                  styleClass="auto-bid-check"/>

                        <TextField fx:id="txtAutoBidMax"
                                   promptText="Giá tối đa (VNĐ)"
                                   disable="true"
                                   styleClass="auto-bid-input"/>

                        <TextField fx:id="txtAutoBidIncrement"
                                   promptText="Bước tăng (mặc định = bước giá)"
                                   disable="true"
                                   styleClass="auto-bid-input"/>


                        <Label text="Hệ thống tự đặt thay bạn khi bị vượt giá, không vượt giá tối đa."
                               styleClass="auto-bid-hint"
                               wrapText="true"/>
                    </VBox>
                    <Separator styleClass="panel-sep"/>

                    <!-- ⑤ Seller info -->
                    <VBox styleClass="panel-section" spacing="6">
                        <Label text="🏪  Người bán" styleClass="panel-section-title"/>

                        <Label fx:id="lblSellerName"   text="—" styleClass="seller-name"/>
                        <Label fx:id="lblSellerRating" text="⭐ —" styleClass="seller-rating"/>
                        <Label fx:id="lblSellerProducts" text="Sản phẩm đã bán: —" styleClass="seller-meta"/>

                        <HBox spacing="8" style="-fx-padding: 4 0 0 0;">
                            <Button text="Xem profile"
                                    onAction="#handleViewSellerProfile"
                                    styleClass="btn-secondary"
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </right>

</BorderPane>