<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="30" styleClass="balance-root" stylesheets="@../style/style.css" fx:controller="com.auction.client.controller.BalanceController"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1">

    <!-- Title -->
    <Label text="Current Balance" styleClass="title" />

    <!-- Card -->
    <StackPane styleClass="balance-card">
        <VBox alignment="CENTER" spacing="10">
            <Label text="Your Balance" styleClass="sub-text"/>
            <Label fx:id="balanceLabel" text="0 VND" styleClass="balance-amount"/>
        </VBox>
    </StackPane>

    <!-- Buttons -->
    <HBox spacing="20">
        <Button text="Deposit" styleClass="btn-deposit"/>
        <Button text="Withdraw" styleClass="btn-withdraw"/>
    </HBox>

    <!-- History -->
    <Label text="Deposit History" styleClass="section-title"/>

    <TableView VBox.vgrow="ALWAYS"/>
</VBox>
