<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1000.0"
            styleClass="main-container"
            stylesheets="@../style/AdminRoomManagementStyle.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.AdminRoomManagementController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="top-bar" spacing="15">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <VBox>
                <Label styleClass="header-title" text="Giám Sát Phòng Đấu Giá"/>
                <Label styleClass="header-subtitle"
                       text="Realtime monitoring hệ thống đấu giá"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <TextField fx:id="searchField"
                       promptText="Tìm phòng / sản phẩm..."
                       prefWidth="250"/>

            <Button onAction="#handleRefresh"
                    styleClass="btn-refresh"
                    text="🔄 Refresh"/>
        </HBox>
    </top>

    <!-- CENTER: MASTER - DETAIL -->
    <center>
        <SplitPane dividerPositions="0.45">

            <!-- LEFT: TABLE LIST (MASTER) -->
            <VBox styleClass="left-panel" spacing="10">

                <Label text="Active Auction Rooms"
                       styleClass="section-title"/>

                <TableView fx:id="roomTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRoomId" text="Room" prefWidth="80"/>
                        <TableColumn fx:id="colItem" text="Item" prefWidth="160"/>
                        <TableColumn fx:id="colPrice" text="Current Price" prefWidth="120"/>
                        <TableColumn fx:id="colBids" text="Bids" prefWidth="70"/>
                        <TableColumn fx:id="colTime" text="Time Left" prefWidth="100"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                    </columns>
                </TableView>

            </VBox>

            <!-- RIGHT: DETAIL INSPECTOR (DETAIL) -->
            <VBox styleClass="right-panel" spacing="12">

                <Label text="Room Inspector"
                       styleClass="section-title"/>

                <VBox styleClass="card">

                    <Label fx:id="lblRoomId" text="Room: -"/>
                    <Label fx:id="lblItem" text="Item: -"/>
                    <Label fx:id="lblStartPrice" text="Start Price: -"/>
                    <Label fx:id="lblCurrentPrice" text="Current: -"/>
                    <Label fx:id="lblHighestBidder" text="Highest Bidder: -"/>
                    <Label fx:id="lblTimeLeft" text="Time Left: -"/>

                </VBox>

                <TitledPane text="Live Bid Activity" expanded="true">
                    <TextArea fx:id="logArea"
                              editable="false"
                              wrapText="true"
                              prefHeight="250"/>
                </TitledPane>

                <TitledPane text="Participants" expanded="false">
                    <ListView fx:id="participantList"/>
                </TitledPane>

            </VBox>

        </SplitPane>
    </center>

    <!-- BOTTOM STATUS BAR -->
    <bottom>
        <HBox styleClass="bottom-bar" spacing="10">
            <padding>
                <Insets top="8" right="15" bottom="8" left="15"/>
            </padding>

            <Label text="System Status:"/>
            <Label fx:id="lblSystemStatus" text="ONLINE" styleClass="status-ok"/>

        </HBox>
    </bottom>

</BorderPane>