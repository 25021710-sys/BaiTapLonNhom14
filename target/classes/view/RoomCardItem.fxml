<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<?import javafx.geometry.Insets?>
<VBox fx:id="cardRoot" onMouseClicked="#onCardClicked" prefWidth="220.0" spacing="10.0" styleClass="room-card"
      stylesheets="@../style/AdminRoomManagementStyle.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <StackPane prefHeight="140.0" styleClass="image-container">
            <ImageView fx:id="imgProduct" fitHeight="130.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
            <Label fx:id="lblStatus" styleClass="status-badge" text="LIVE" StackPane.alignment="TOP_RIGHT" />
        </StackPane>

        <VBox spacing="5.0">
            <Label fx:id="lblProductName" styleClass="product-title" text="Tên sản phẩm đấu giá" />
            <HBox alignment="CENTER_LEFT" spacing="5.0">
                <Label text="Giá hiện tại:" styleClass="label-small" />
                <Label fx:id="lblCurrentPrice" styleClass="price-text" text="500,000đ" />
            </HBox>
            <Separator />
            <Label fx:id="lblTimeLeft" styleClass="time-text" text="Còn lại: 02:15:30" />
        </VBox>
    </children>
    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
</VBox>