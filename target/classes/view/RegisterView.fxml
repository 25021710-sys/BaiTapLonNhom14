<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER_LEFT" prefHeight="570.0" prefWidth="578.0" spacing="12" style="-fx-background-color: ALICEBLUE;" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.RegisterController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="84.0" prefWidth="546.0" text="Create a new account in Auction Online" textAlignment="CENTER" textFill="#298a85">
        <VBox.margin>
            <Insets />
        </VBox.margin>
        <font>
            <Font name="Arial Bold" size="28.0" />
        </font>
    </Label>
    <Label opacity="0.29" prefHeight="24.0" prefWidth="139.0" style="fx-font-size: 18px; -fx-font-weight: bold;" text="Please enter your details" textFill="#114646">
        <VBox.margin>
            <Insets />
        </VBox.margin></Label>
    <Label prefHeight="10" prefWidth="80.0" text="Email Address">
        <VBox.margin>
            <Insets />
        </VBox.margin></Label>
    <TextField fx:id="emailField" prefHeight="34.0" prefWidth="538.0">
        <VBox.margin>
            <Insets />
        </VBox.margin></TextField>
    <Label prefHeight="10" prefWidth="80.0" text="Username">
        <VBox.margin>
            <Insets />
        </VBox.margin></Label>
    <TextField fx:id="usernameField" prefHeight="34.0" prefWidth="538.0">
        <VBox.margin>
            <Insets />
        </VBox.margin></TextField>
    <Label prefHeight="17.0" prefWidth="58.0" text="Password">
        <VBox.margin>
            <Insets />
        </VBox.margin></Label>
    <PasswordField fx:id="passwordField" prefHeight="34.0" prefWidth="538.0" />
    <Label fx:id="errorLabel" textFill="#227d80" visible="false" />
    <Button alignment="CENTER" onAction="#handleSignup" prefHeight="38.0" prefWidth="563.0" styleClass="primary-button" text="Sign up" />
    <TextFlow textAlignment="CENTER">
        <Text text="Already have an account? " />
        <Hyperlink onAction="#goToLogin" text="Sign in" />
    </TextFlow>
</VBox>
