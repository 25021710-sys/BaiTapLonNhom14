<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="260.0" prefWidth="200.0"
      spacing="8.0"
      style="-fx-background-color: #142932; -fx-background-radius: 15;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1">

   <!-- HEADER -->
   <HBox alignment="TOP_LEFT" spacing="6.0">
      <VBox spacing="1.0" HBox.hgrow="ALWAYS">
         <Label text="Thịnh Văn Đức"
                styleClass="label-value"
                stylesheets="@../style/ProductCards.css"/>

         <Label text="#1001"
                styleClass="label-title"
                stylesheets="@../style/ProductCards.css"/>
      </VBox>

      <Button mnemonicParsing="false"
              style="-fx-background-color: transparent;"
              prefWidth="22.0"
              prefHeight="22.0">
         <graphic>
            <FontAwesomeIcon fill="WHITE" glyphName="ELLIPSIS_V" size="14"/>
         </graphic>
      </Button>

      <HBox.margin>
         <Insets top="4.0" right="4.0"/>
      </HBox.margin>
   </HBox>

   <!-- IMAGE -->
   <StackPane prefHeight="95.0"
              style="-fx-background-color: #0f2026; -fx-background-radius: 12;">
      <children>
         <Label text="No Image"
                textFill="#95A5A6"
                style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
      </children>

      <VBox.margin>
         <Insets left="6.0" right="6.0"/>
      </VBox.margin>
   </StackPane>

   <!-- TIME BAR -->
   <HBox alignment="CENTER_LEFT"
         spacing="5.0"
         styleClass="time-bar"
         stylesheets="@../style/ProductCards.css"
         style="-fx-background-radius: 10;">
      <children>
         <FontAwesomeIcon fill="WHITE" glyphName="CLOCK_ALT" size="12"/>

         <Label text="Kết thúc trong 10 giờ"
                textFill="WHITE">
            <font>
               <Font size="11.0"/>
            </font>
         </Label>
      </children>

      <padding>
         <Insets top="4.0" bottom="4.0" left="8.0" right="8.0"/>
      </padding>

      <VBox.margin>
         <Insets left="6.0" right="6.0"/>
      </VBox.margin>
   </HBox>

   <!-- PRICE INFO -->
   <HBox spacing="6.0">
      <VBox alignment="CENTER"
            spacing="3.0"
            style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 10;"
            HBox.hgrow="ALWAYS">
         <children>
            <Label text="Khởi điểm"
                   styleClass="label-title"
                   stylesheets="@../style/ProductCards.css"/>

            <Label text="15.000"
                   styleClass="label-value"
                   stylesheets="@../style/ProductCards.css"/>
         </children>

         <padding>
            <Insets top="6.0" bottom="6.0"/>
         </padding>
      </VBox>

      <VBox alignment="CENTER"
            spacing="3.0"
            style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 10;"
            HBox.hgrow="ALWAYS">
         <children>
            <Label text="Hiện tại"
                   styleClass="label-title"
                   stylesheets="@../style/ProductCards.css"/>

            <Label text="150.000"
                   styleClass="label-value"
                   stylesheets="@../style/ProductCards.css"/>
         </children>

         <padding>
            <Insets top="6.0" bottom="6.0"/>
         </padding>
      </VBox>

      <VBox.margin>
         <Insets left="6.0" right="6.0"/>
      </VBox.margin>
   </HBox>

   <!-- BUTTON -->
   <Button mnemonicParsing="false"
           prefHeight="28.0"
           maxWidth="1.7976931348623157E308"
           style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;"
           text="Tham gia">
      <font>
         <Font size="12.0"/>
      </font>

      <VBox.margin>
         <Insets left="6.0" right="6.0" bottom="8.0"/>
      </VBox.margin>
   </Button>

   <padding>
      <Insets top="8.0" left="8.0" right="8.0" bottom="8.0"/>
   </padding>

</VBox>