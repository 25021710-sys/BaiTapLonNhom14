<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" fillWidth="false" prefHeight="580.0" prefWidth="500.0" spacing="30" styleClass="profile-content" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.ProfileContentController">
    <padding>
        <Insets bottom="40" left="40" right="40" top="40" />
    </padding>

    <VBox maxWidth="700.0" spacing="30" VBox.vgrow="ALWAYS">

        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d3436;" text="User Profile" />

        <GridPane hgap="40.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints minWidth="150.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="250.0" prefWidth="400.0" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints minHeight="35.0" /> <RowConstraints />
                <RowConstraints minHeight="35.0" /> <RowConstraints />
                <RowConstraints minHeight="35.0" /> <RowConstraints />
                <RowConstraints minHeight="35.0" /> <RowConstraints />
                <RowConstraints minHeight="35.0" />
            </rowConstraints>

            <Label style="-fx-text-fill: #636e72; -fx-font-size: 14px;" text="Name" GridPane.rowIndex="0" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label fx:id="nameLabel" text="Label" style="-fx-font-weight: bold;" />
                <TextField fx:id="nameField" visible="false" />
            </StackPane>
            <Separator GridPane.columnSpan="2" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: #636e72; -fx-font-size: 14px;" text="Email account" GridPane.rowIndex="2" />
            <Label fx:id="displayEmail" text="an.nguyen@gmail.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Separator GridPane.columnSpan="2" GridPane.rowIndex="3" />

            <Label style="-fx-text-fill: #636e72; -fx-font-size: 14px;" text="Location" GridPane.rowIndex="4" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="4">
                <Label fx:id="locationLabel" text="Label" />
                <TextField fx:id="locationField" visible="false" />
            </StackPane>
            <Separator GridPane.columnSpan="2" GridPane.rowIndex="5" />

            <Label style="-fx-text-fill: #636e72; -fx-font-size: 14px;" text="Description" GridPane.rowIndex="6" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="6">
                <Label fx:id="desLabel" text="Label" />
                <TextField fx:id="desField" visible="false" />
            </StackPane>
            <Separator GridPane.columnSpan="2" GridPane.rowIndex="7" />

            <Label style="-fx-text-fill: #636e72; -fx-font-size: 14px;" text="Password" GridPane.rowIndex="8" />
            <StackPane alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="8">
                <Label fx:id="passLabel" text="Label" />
                <PasswordField fx:id="passField" visible="false" />
            </StackPane>
        </GridPane>

        <HBox spacing="15">
            <Button fx:id="editButton" onAction="#handleEdit" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #006266; -fx-text-fill: white; -fx-cursor: hand;" text="Edit" />
            <Button fx:id="cancelButton" onAction="#handleCancel" prefHeight="35.0" prefWidth="100.0" text="Cancel" visible="false" />
        </HBox>
    </VBox>
</VBox>