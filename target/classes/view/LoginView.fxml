<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<VBox alignment="CENTER_LEFT" prefHeight="570.0" prefWidth="578.0" spacing="12" style="-fx-background-color: ALICEBLUE;" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="96.0" prefWidth="538.0" text="Welcome to Auction Online " textAlignment="CENTER" textFill="#298a85">
      <VBox.margin>
         <Insets />
      </VBox.margin>
      <font>
         <Font name="Arial Bold" size="28.0" />
      </font>
    </Label>
    <Label opacity="0.29" prefHeight="24.0" prefWidth="139.0" style="fx-font-size: 18px; -fx-font-weight: bold;" text="Please enter your details" textFill="#114646">
      <VBox.margin>
         <Insets />
      </VBox.margin></Label>
    <Label prefHeight="10" prefWidth="80.0" text="Email Address">
      <VBox.margin>
         <Insets />
      </VBox.margin></Label>
    <TextField fx:id="emailField" prefWidth="200">
      <VBox.margin>
         <Insets />
      </VBox.margin></TextField>
    <Label prefHeight="17.0" prefWidth="58.0" text="Password">
      <VBox.margin>
         <Insets />
      </VBox.margin></Label>
    <PasswordField fx:id="passwordField" prefWidth="200" />
    <Label fx:id="errorLabel" textFill="#227d80" visible="false" />
    <Button alignment="CENTER" onAction="#handleLogin" prefHeight="38.0" prefWidth="563.0" text="Sign in" />
    <TextFlow textAlignment="CENTER">
        <Text text="Don't have an account? " />
        <Hyperlink onAction="#goToRegister" text="Register" />
    </TextFlow>
</VBox>
